  "type": "module",
  "bin": {
    "hopla-claude-setup": "cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HOPLAtools/claude-setup.git"
  },
  "homepage": "https://github.com/HOPLAtools/claude-setup#readme",
